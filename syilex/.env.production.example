###############################################
# POSIP Production Environment — TEMPLATE
#
# INSTRUKSI:
# 1. Copy file ini ke .env di server production
# 2. Isi value TODO sesuai environment
# 3. JANGAN commit .env yang terisi ke git
# 4. Jalankan: php artisan config:cache && php artisan route:cache
###############################################

APP_NAME=POSIP
APP_ENV=production              # ← WAJIB: production
APP_KEY=                         # TODO: php artisan key:generate
APP_DEBUG=false                  # ← WAJIB: false (cegah stack trace bocor)
APP_URL=https://posip.yourdomain.com
APP_TIMEZONE=Asia/Jakarta

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# Logging: warning untuk production (hindari log bengkak)
LOG_CHANNEL=daily
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning                # ← WAJIB: warning/error (jangan debug)

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=                     # TODO: isi nama DB production
DB_USERNAME=                     # TODO: isi user DB
DB_PASSWORD=                     # TODO: isi password DB

FRONTEND_URL=https://posip.yourdomain.com

# Session — ENCRYPT wajib true untuk production
SESSION_DRIVER=file              # atau 'redis' untuk multi-server
SESSION_LIFETIME=120
SESSION_ENCRYPT=true             # ← WAJIB: true untuk enkripsi cookie session
SESSION_PATH=/
SESSION_DOMAIN=.yourdomain.com   # TODO: set domain (leading dot untuk subdomain)
SESSION_SECURE_COOKIE=true       # ← Cookie hanya via HTTPS
SESSION_SAME_SITE=lax

SANCTUM_STATEFUL_DOMAINS=posip.yourdomain.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: untuk production pakai database atau redis, jangan sync
QUEUE_CONNECTION=database        # ← Atau 'redis' kalau pakai Redis

# Cache: file OK untuk single server, redis untuk multi-server
CACHE_STORE=file                 # ← Atau 'redis' untuk scale horizontal

# Mail — isi kredensial SMTP production
MAIL_MAILER=smtp
MAIL_HOST=                       # TODO: smtp.yourmail.com
MAIL_PORT=587
MAIL_USERNAME=                   # TODO
MAIL_PASSWORD=                   # TODO
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourdomain.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

###############################################
# POST-DEPLOY CHECKLIST:
# [ ] php artisan key:generate (sekali saja di first deploy)
# [ ] php artisan migrate --force
# [ ] php artisan config:cache
# [ ] php artisan route:cache
# [ ] php artisan view:cache
# [ ] php artisan storage:link
# [ ] php artisan queue:work --daemon (via supervisor)
# [ ] Pastikan folder storage/ writable oleh web server
###############################################
